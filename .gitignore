# Unity standard gitignore
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
/[Bb]uild*/
[Ll]ogs/
[Mm]emoryCaptures/
/[Vv]isualStudio/

# Asset meta data when using external version control
# .meta files should be included

# UserSettings should be ignored as they are local to the editor
[Uu]ser[Ss]ettings/

# IDE folders
.vs/
.vscode/
bin/
obj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.IDB
*.v12.suo
*.v13.suo
*.v14.suo
*.v15.suo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db
